---
import { StatsNav } from "../components/stats/StatsNav";
import SourceRepoLink from "../components/SourceRepoLink.astro";
import { ThemeToggle } from "../components/ThemeToggle";
import eurovisionHeart from "../assets/brand/eurovision-70-heart.webp";
import "../styles/global.css";

type Props = {
  title: string;
  current: "videos" | "songs" | "episodes" | "insights";
};

const { title, current } = Astro.props;
const pageTitle = `${title} · Eurovision Top 20`;
const iconBase = import.meta.env.BASE_URL;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={pageTitle} />
    <title>{pageTitle}</title>
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href={`${iconBase}favicon-32x32.png`}
    />
    <link rel="apple-touch-icon" href={`${iconBase}apple-touch-icon.png`} />
    <script is:inline>
      (function () {
        var key = "theme";
        var stored = localStorage.getItem(key);
        var dark =
          stored === "dark" ||
          (stored !== "light" &&
            window.matchMedia("(prefers-color-scheme: dark)").matches);
        document.documentElement.classList.toggle("dark", dark);
      })();
    </script>
  </head>
  <body class="min-h-screen">
    <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
      <header class="mb-8">
        <div class="flex items-start justify-between gap-4">
          <h1 class="flex min-w-0 items-center gap-3 text-3xl font-bold tracking-tight">
            <img
              src={eurovisionHeart.src}
              alt=""
              width={36}
              height={36}
              class="h-9 w-9 shrink-0"
              decoding="async"
            />
            Eurovision Top 20
          </h1>
          <div class="flex shrink-0 items-center gap-2">
            <SourceRepoLink />
            <ThemeToggle client:load />
          </div>
        </div>

        <div class="mt-3">
          <StatsNav client:load current={current} />
        </div>
      </header>

      <slot />

      <footer class="mt-12 border-t border-border pt-6 text-xs text-text-muted">
        <p>
          ESC placement data from
          <a
            href="https://github.com/EurovisionAPI/dataset"
            target="_blank"
            rel="noopener noreferrer"
            class="text-accent hover:underline"
          >
            EurovisionAPI Eurovision Song Contest Dataset
          </a>.
        </p>
      </footer>
    </main>
  </body>
</html>
