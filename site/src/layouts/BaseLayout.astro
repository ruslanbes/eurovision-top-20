---
import { ThemeToggle } from "../components/ThemeToggle";
import "../styles/global.css";

type Props = {
  title: string;
  description: string;
  current: "videos" | "songs";
};

const { title, description, current } = Astro.props;
const base = import.meta.env.BASE_URL;
const pageTitle = `${title} · Eurovision Top 20`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
    <script is:inline>
      (function () {
        var key = "theme";
        var stored = localStorage.getItem(key);
        var dark =
          stored === "dark" ||
          (stored !== "light" &&
            window.matchMedia("(prefers-color-scheme: dark)").matches);
        document.documentElement.classList.toggle("dark", dark);
      })();
    </script>
  </head>
  <body class="min-h-screen">
    <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
      <header class="mb-8 space-y-4">
        <div class="flex items-start justify-between gap-4">
          <div class="min-w-0 space-y-2">
            <h1 class="text-3xl font-bold tracking-tight">Eurovision Top 20</h1>
            <p class="max-w-2xl text-text-muted">
              {description}
            </p>
          </div>
          <ThemeToggle client:load />
        </div>

        <nav
          aria-label="Stats views"
          class="flex gap-1 rounded-lg border border-border bg-surface-elevated p-1"
        >
          <a
            href={base}
            aria-current={current === "videos" ? "page" : undefined}
            class:list={[
              "rounded-md px-4 py-2 text-sm font-medium transition-colors",
              current === "videos"
                ? "bg-surface text-text shadow-sm"
                : "text-text-muted hover:text-text",
            ]}
          >
            Videos
          </a>
          <a
            href={`${base}songs/`}
            aria-current={current === "songs" ? "page" : undefined}
            class:list={[
              "rounded-md px-4 py-2 text-sm font-medium transition-colors",
              current === "songs"
                ? "bg-surface text-text shadow-sm"
                : "text-text-muted hover:text-text",
            ]}
          >
            Songs
          </a>
        </nav>
      </header>

      <slot />
    </main>
  </body>
</html>
