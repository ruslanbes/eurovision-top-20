---
import "../styles/global.css";

type Props = {
  title: string;
  description: string;
  current: "videos" | "songs";
};

const { title, description, current } = Astro.props;
const base = import.meta.env.BASE_URL;
const pageTitle = `${title} · Eurovision Top 20`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
  </head>
  <body class="min-h-screen">
    <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
      <header class="mb-8 space-y-4">
        <div class="space-y-2">
          <h1 class="text-3xl font-bold tracking-tight">Eurovision Top 20</h1>
          <p class="max-w-2xl text-zinc-600 dark:text-zinc-400">
            {description}
          </p>
        </div>

        <nav
          aria-label="Stats views"
          class="flex gap-1 rounded-lg border border-zinc-200 bg-zinc-50 p-1 dark:border-zinc-800 dark:bg-zinc-900"
        >
          <a
            href={base}
            aria-current={current === "videos" ? "page" : undefined}
            class:list={[
              "rounded-md px-4 py-2 text-sm font-medium transition-colors",
              current === "videos"
                ? "bg-white text-zinc-900 shadow-sm dark:bg-zinc-950 dark:text-zinc-100"
                : "text-zinc-600 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100",
            ]}
          >
            Videos
          </a>
          <a
            href={`${base}songs/`}
            aria-current={current === "songs" ? "page" : undefined}
            class:list={[
              "rounded-md px-4 py-2 text-sm font-medium transition-colors",
              current === "songs"
                ? "bg-white text-zinc-900 shadow-sm dark:bg-zinc-950 dark:text-zinc-100"
                : "text-zinc-600 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100",
            ]}
          >
            Songs
          </a>
        </nav>
      </header>

      <slot />
    </main>
  </body>
</html>
