---
import { StatsNav } from "../components/stats/StatsNav";
import { ThemeToggle } from "../components/ThemeToggle";
import "../styles/global.css";

type Props = {
  title: string;
  description: string;
  current: "videos" | "songs";
};

const { title, description, current } = Astro.props;
const pageTitle = `${title} · Eurovision Top 20`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
    <script is:inline>
      (function () {
        var key = "theme";
        var stored = localStorage.getItem(key);
        var dark =
          stored === "dark" ||
          (stored !== "light" &&
            window.matchMedia("(prefers-color-scheme: dark)").matches);
        document.documentElement.classList.toggle("dark", dark);
      })();
    </script>
  </head>
  <body class="min-h-screen">
    <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
      <header class="mb-8 space-y-4">
        <div class="flex items-start justify-between gap-4">
          <div class="min-w-0 space-y-2">
            <h1 class="text-3xl font-bold tracking-tight">Eurovision Top 20</h1>
            <p class="max-w-2xl text-text-muted">
              {description}
            </p>
          </div>
          <ThemeToggle client:load />
        </div>

        <StatsNav client:load current={current} />
      </header>

      <slot />
    </main>
  </body>
</html>
